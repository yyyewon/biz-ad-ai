# FastAPI 백엔드 주소
API_BASE_URL=http://backend:8010
API_BROWSER_BASE_URL=http://localhost:8010

# 백엔드 없이 프론트만 테스트하고 싶을 때 true, 실제 연동 시 false
RG_MOCK_MODE=false
RG_DEV_GUEST_MODE=false

# 참고: 실제 OpenAI 호출은 백엔드에서 수행합니다.
# 배포/개발 환경에서 프론트-백엔드 설정을 한 파일에서 관리할 때를 위해 템플릿으로 유지합니다.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1-mini
OPENAI_IMAGE_SIZE=1080x1350