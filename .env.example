# 사용: cp .env.example .env 후 본인 계정·포트만 수정 (.env 는 Git 제외)
# 상세: docs/metrics-setup-guide.md

# ── Jupyter proxy (docker-compose.dev.proxy.yml 과 맞출 것) ──
API_BROWSER_BASE_URL=http://34.60.252.165:8000/user/YOUR_USER/proxy/YOUR_BACKEND_PORT

# ── Metrics / JSONL (팀 공용, 권장) ──
METRICS_LOG_HOST_PATH=/opt/biz-ad-ai-team-logs
METRICS_SOURCE_USER=YOUR_USER
METRICS_BACKEND_PORT=YOUR_BACKEND_PORT
METRICS_FRONTEND_PORT=YOUR_FRONTEND_PORT
METRICS_DEPLOY_ENV=dev

# ── 본인만 테스트 (팀 8555에 안 보임) ──
# 위 METRICS_* 블록을 주석 처리하고 compose up → 기본 ./backend/logs-dev 사용

# ── 배포 prod (/opt/biz-ad-ai/.env 참고) ──
# METRICS_LOG_HOST_PATH=/opt/biz-ad-ai-team-logs
# METRICS_SOURCE_USER=prod
# METRICS_BACKEND_PORT=8010
# METRICS_FRONTEND_PORT=8501
# METRICS_DEPLOY_ENV=prod
