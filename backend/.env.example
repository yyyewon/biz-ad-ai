# =========================
# CORS
# =========================
CORS_ALLOWED_ORIGINS=http://localhost:8501, http://34.60.252.165:8501

# =========================
# OPENAI
# =========================
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1-mini
OPENAI_IMAGE_SIZE=1024x1536

# =========================
# JWT
# =========================
JWT_SECRET_KEY=
JWT_EXPIRES_SECONDS=604800

# =========================
# Kakao OAuth
# =========================
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://34.60.252.165:8010/api/v1/auth/kakao/callback
FRONTEND_BASE_URL=http://34.60.252.165:8501

# =========================
# 동시성 제어
# =========================
GENERATION_MAX_CONCURRENT=2
GENERATION_QUEUE_TIMEOUT_SECONDS=15

# =========================
# 일일 생성 횟수 제한
# =========================
DAILY_GENERATION_LIMIT=3

# =========================
# 개발자 도구 (테스트용)
# =========================
DEV_TOOLS_ENABLED=true

# =========================
# HuggingFace / 모델 캐시 (VM 가상환경 권장)
# =========================
# HF_HOME=
# U2NET_HOME=
# 예: HF_HOME=/home/spai0908/biz-ad-ai/.cache/hf
#     U2NET_HOME=/home/spai0908/biz-ad-ai/.cache/u2net
HF_TOKEN=

# =========================
# 모델 로딩 / 워밍업 안전 설정
# =========================
MODEL_WARMUP_ENABLED=false

# MODEL_WARMUP_ENABLED=true일 때만 적용되는 모델별 워밍업 설정
WARMUP_HF_IMAGE_ENABLED=true
WARMUP_POSTER_VLM_ENABLED=false
WARMUP_FOOD_CLASSIFIER_ENABLED=false
WARMUP_POSTER_LAYOUT_ENABLED=true

# 모델 로딩 직전 필요한 최소 available RAM(GB). 0이면 검사를 비활성화
MODEL_LOAD_MIN_AVAILABLE_RAM_GB=6

# true이면 CUDA 전체 이동 대신 Diffusers CPU offload 사용
HF_IMAGE_CPU_OFFLOAD_ENABLED=false
